# === Database (Postgres container) ===
POSTGRES_USER=see_user
POSTGRES_PASSWORD=              # openssl rand -hex 16
POSTGRES_DB=see_db

# === Database (App connection, hostname = compose service name "db") ===
DATABASE_URL=postgresql://see_user:<POSTGRES_PASSWORD>@db:5432/see_db

# === NextAuth ===
NEXTAUTH_URL=https://see.tbsf.tw
NEXTAUTH_SECRET=                # openssl rand -base64 32

# === SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tbsfnoreply@gmail.com
SMTP_PASS=                      # Gmail App Password
SMTP_FROM=IT Security <tbsfnoreply@gmail.com>

# === App ===
BASE_URL=https://see.tbsf.tw

# === Initial Admin (used by seed script, first deploy only) ===
ADMIN_EMAIL=admin@see.local
ADMIN_PASSWORD=                 # Will be bcrypt hashed by seed script
